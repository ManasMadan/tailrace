{
  "publication": "walcast_demo",
  "slot": "walcast_demo",
  "server": { "port": 7717, "host": "0.0.0.0", "authToken": "demo" },
  "sinks": [
    { "use": "@walcast/sink-sse", "name": "sse" },
    {
      "use": "@walcast/sink-webhook",
      "name": "demo-webhook",
      "config": { "url": "http://receiver:9799/hook", "secret": "demo-secret" }
    },
    {
      "use": "@walcast/sink-kafka",
      "name": "demo-kafka",
      "config": { "brokers": ["kafka:9092"], "topicPrefix": "demo" }
    }
  ]
}
